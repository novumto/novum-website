---
// src/pages/tw/card.astro
---
<!DOCTYPE html>
<html lang="zh-Hant-TW">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>AI 數位名片 | NOVUM</title>

  <meta name="description" content="NOVUM 幫你做一張讓 AI 認識你的名片頁面，當有人用 ChatGPT 問附近有什麼好吃的，你的品牌才有機會被提到。">
  <link rel="canonical" href="https://novum.to/ai-index/tw/card">

  <meta property="og:title"       content="AI 數位名片 | NOVUM">
  <meta property="og:description" content="NOVUM 幫你做一張讓 AI 認識你的名片頁面，當有人用 ChatGPT 問附近有什麼好吃的，你的品牌才有機會被提到。">
  <meta property="og:type"        content="website">
  <meta property="og:locale"      content="zh_TW">
  <meta property="og:url"         content="https://novum.to/ai-index/tw/card">
  <meta property="og:image"       content="https://novum.to/ai-index/tw/food/ai-index-og-image.png">
  <meta property="og:site_name"   content="NOVUM AI Index">

  <meta name="twitter:card"        content="summary_large_image">
  <meta name="twitter:title"       content="AI 數位名片 | NOVUM">
  <meta name="twitter:description" content="NOVUM 幫你做一張讓 AI 認識你的名片頁面，當有人用 ChatGPT 問附近有什麼好吃的，你的品牌才有機會被提到。">
  <meta name="twitter:image"       content="https://novum.to/ai-index/tw/food/ai-index-og-image.png">

  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@graph": [
      {
        "@type": "Service",
        "@id": "https://novum.to/ai-index/tw/card#service",
        "name": "AI 數位名片",
        "url": "https://novum.to/ai-index/tw/card",
        "description": "NOVUM 為台灣品牌提供 AI 數位名片服務，包含客製化頁面設計、Schema 結構化資料建置、專屬短網址，以及 NOVUM AI Index 目錄收錄，協助品牌增加曝光出現在 ChatGPT、Gemini、Perplexity 等 AI 工具中。",
        "provider": {"@type": "Organization", "name": "NOVUM", "url": "https://novum.to"},
        "areaServed": {"@type": "Place", "name": "台灣"},
        "offers": {
          "@type": "Offer",
          "priceCurrency": "TWD",
          "price": "8800",
          "description": "建置費（一次性），含頁面設計與所有技術設定"
        }
      },
      {
        "@type": "WebPage",
        "@id": "https://novum.to/ai-index/tw/card#webpage",
        "url": "https://novum.to/ai-index/tw/card",
        "name": "AI 數位名片 | NOVUM",
        "description": "NOVUM 幫你做一張讓 AI 認識你的名片頁面，當有人用 ChatGPT 問附近有什麼好吃的，你的品牌才有機會被提到。",
        "inLanguage": "zh-TW",
        "isPartOf": {"@type": "WebSite", "name": "NOVUM", "url": "https://novum.to"},
        "breadcrumb": {"@id": "https://novum.to/ai-index/tw/card#breadcrumb"}
      },
      {
        "@type": "BreadcrumbList",
        "@id": "https://novum.to/ai-index/tw/card#breadcrumb",
        "itemListElement": [
          {"@type": "ListItem", "position": 1, "name": "NOVUM",       "item": "https://novum.to"},
          {"@type": "ListItem", "position": 2, "name": "AI Index",    "item": "https://novum.to/ai-index"},
          {"@type": "ListItem", "position": 3, "name": "AI 數位名片", "item": "https://novum.to/ai-index/tw/card"}
        ]
      }
    ]
  }
  </script>

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Roboto+Slab:wght@700;900&family=Noto+Sans+TC:wght@400;500;700;900&display=swap" rel="stylesheet">

  <style>
    :root {
      --bg:          #0E2A1A;
      --bg-surface:  #122d1d;
      --bg-card:     rgba(255,255,255,0.05);
      --border:      rgba(255,255,255,0.09);
      --border-green:rgba(61,184,106,0.25);
      --text:        #f4f6fc;
      --text-dim:    rgba(244,246,252,0.90);
      --text-muted:  rgba(244,246,252,0.65);
      --green:       #3DB86A;
      --green-soft:  rgba(61,184,106,0.12);
      --green-hover: #34a35d;
      --yellow:      #FFE234;
    }

    * { margin: 0; padding: 0; box-sizing: border-box; }
    html { scroll-behavior: smooth; }

    body {
      background-color: var(--bg);
      font-family: 'Noto Sans TC', sans-serif;
      font-size: 16px;
      line-height: 1.8;
      color: var(--text);
      min-height: 100vh;
      overflow-x: hidden;
    }

    /* grain texture — z-index 낮춰야 nav overlay 위에 안 올라옴 */
    body::before {
      content: '';
      position: fixed;
      inset: -50px;
      pointer-events: none;
      z-index: 999;
      opacity: 0.04;
      background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 512 512' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='grain'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.72' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23grain)'/%3E%3C/svg%3E");
      background-size: 220px 220px;
      mix-blend-mode: screen;
    }

    .hero {
      min-height: 100vh;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      text-align: center;
      padding: 80px 32px 90px;
      position: relative;
    }
    .hero::before {
      content: '';
      position: absolute;
      top: 10%; left: 50%; transform: translateX(-50%);
      width: 700px; height: 500px;
      background: radial-gradient(ellipse at center, rgba(61,184,106,0.10) 0%, transparent 68%);
      pointer-events: none;
    }
    .hero-eyebrow {
      font-size: 15px;
      font-weight: 700;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--green);
      margin-bottom: 24px;
      display: inline-flex;
      align-items: center;
      gap: 8px;
    }
    .hero-eyebrow::before,
    .hero-eyebrow::after {
      content: '';
      display: inline-block;
      width: 28px; height: 1px;
      background: var(--green);
      opacity: 0.5;
    }
    .hero h1 {
      font-family: 'Roboto Slab', serif;
      font-weight: 900;
      font-size: clamp(52px, 10vw, 90px);
      line-height: 0.95;
      margin-bottom: 32px;
      color: var(--text);
      letter-spacing: -0.02em;
    }
    .hero h1 em { font-style: normal; color: var(--green); }
    .hero-sub {
      font-size: clamp(16px, 2.2vw, 19px);
      color: var(--text-dim);
      line-height: 1.9;
      max-width: 520px;
      margin: 0 auto;
      font-weight: 400;
    }

    .demo-section,
    .why-section,
    .whyus-section,
    .includes-section,
    .steps-section,
    .pricing-section {
      padding: 88px 32px;
      max-width: 880px;
      margin: 0 auto;
    }
    .demo-section    { text-align: center; max-width: 880px; }
    .includes-section { text-align: center; }
    .steps-section   { text-align: center; }
    .pricing-section { max-width: 600px; text-align: center; }

    .section-label {
      font-size: 15px;
      font-weight: 700;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--green);
      margin-bottom: 16px;
    }
    .section-title {
      font-family: 'Roboto Slab', serif;
      font-weight: 900;
      font-size: clamp(28px, 5vw, 44px);
      line-height: 0.95;
      margin-bottom: 16px;
      color: var(--text);
      letter-spacing: -0.02em;
    }
    .section-desc {
      font-size: 17px;
      color: var(--text-dim);
      line-height: 1.85;
    }

    .section-divider {
      border: none;
      border-top: 1px solid var(--border);
      max-width: 880px;
      margin: 0 auto;
    }

    .demo-frame-wrap  { max-width: 440px; margin: 0 auto; }
    .demo-frame-label {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      background: var(--bg-card);
      border: 1px solid var(--border);
      border-radius: 99px;
      padding: 6px 18px;
      font-size: 13px;
      color: var(--text-muted);
      margin-bottom: 16px;
    }
    .demo-frame-label span { color: var(--green); font-weight: 700; }
    .demo-frame {
      border-radius: 18px;
      overflow: hidden;
      border: 1px solid var(--border);
      box-shadow: 0 28px 80px rgba(0,0,0,0.45);
    }
    .demo-frame-bar {
      background: rgba(255,255,255,0.04);
      padding: 10px 16px;
      display: flex;
      align-items: center;
      gap: 8px;
      border-bottom: 1px solid var(--border);
    }
    .dot { width: 10px; height: 10px; border-radius: 50%; }
    .dot-r { background: #ff5f57; }
    .dot-y { background: #febc2e; }
    .dot-g { background: #28c840; }
    .demo-url {
      flex: 1;
      background: rgba(255,255,255,0.04);
      border-radius: 6px;
      padding: 4px 10px;
      font-size: 12px;
      color: var(--text-muted);
      text-align: center;
    }
    .demo-iframe { width: 100%; height: 460px; border: none; display: block; pointer-events: none; }
    @media (max-width: 480px) { .demo-iframe { height: 360px; } }
    .demo-cta { margin-top: 18px; }
    .demo-cta a { color: var(--green); text-decoration: none; font-size: 15px; font-weight: 700; }

    .why-cards {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 14px;
      margin-top: 44px;
    }
    @media (max-width: 600px) { .why-cards { grid-template-columns: 1fr; } }
    .why-card {
      background: var(--bg-card);
      border: 1px solid var(--border);
      border-radius: 16px;
      padding: 28px;
      transition: border-color 0.2s;
    }
    .why-card:hover { border-color: var(--border-green); }
    .why-card-icon { font-size: 26px; margin-bottom: 14px; display: block; }
    .why-card h3 { font-weight: 700; font-size: 16px; margin-bottom: 10px; color: var(--text); }
    .why-card p  { font-size: 15px; color: var(--text-dim); line-height: 1.8; }
    .why-card p strong { color: var(--yellow); font-weight: 700; }

    .whyus-list { margin-top: 44px; display: flex; flex-direction: column; gap: 14px; }
    .whyus-item {
      display: flex;
      gap: 24px;
      align-items: flex-start;
      background: var(--bg-card);
      border: 1px solid var(--border);
      border-radius: 16px;
      padding: 26px 28px;
      transition: border-color 0.2s;
    }
    .whyus-item:hover { border-color: var(--border-green); }
    @media (max-width: 480px) { .whyus-item { padding: 20px; gap: 16px; } }
    .whyus-num {
      font-family: 'Roboto Slab', serif;
      font-weight: 900;
      font-size: 26px;
      color: var(--green);
      line-height: 1;
      min-width: 34px;
      opacity: 0.35;
      padding-top: 3px;
    }
    .whyus-content h3 { font-weight: 700; font-size: 17px; margin-bottom: 8px; color: var(--text); }
    .whyus-content p  { font-size: 15px; color: var(--text-dim); line-height: 1.85; }

    .includes-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 12px;
      margin-top: 44px;
      text-align: left;
    }
    @media (max-width: 768px) { .includes-grid { grid-template-columns: 1fr 1fr; } }
    @media (max-width: 520px)  { .includes-grid { grid-template-columns: 1fr; } }
    .include-item {
      background: var(--bg-card);
      border: 1px solid var(--border);
      border-radius: 14px;
      padding: 20px;
      display: flex;
      align-items: flex-start;
      gap: 14px;
      transition: border-color 0.2s;
    }
    .include-item:hover { border-color: var(--border-green); }
    .include-check {
      width: 20px; height: 20px;
      background: var(--green);
      border-radius: 50%;
      display: flex; align-items: center; justify-content: center;
      flex-shrink: 0;
      font-size: 11px;
      color: #fff;
      font-weight: 900;
      margin-top: 2px;
    }
    .include-text { font-size: 14px; color: var(--text-dim); line-height: 1.6; }
    .include-text strong { display: block; color: var(--text); font-weight: 700; margin-bottom: 4px; font-size: 15px; }

    .steps {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 0;
      margin-top: 44px;
      position: relative;
    }
    @media (max-width: 560px) {
      .steps { grid-template-columns: 1fr; gap: 16px; }
      .steps::before { display: none; }
    }
    .steps::before {
      content: '';
      position: absolute;
      top: 27px;
      left: calc(16.66% + 18px);
      right: calc(16.66% + 18px);
      height: 1px;
      background: var(--border);
    }
    .step { display: flex; flex-direction: column; align-items: center; padding: 0 20px; text-align: center; }
    .step-num {
      width: 54px; height: 54px;
      background: var(--bg-card);
      border: 1px solid var(--border-green);
      border-radius: 50%;
      display: flex; align-items: center; justify-content: center;
      font-family: 'Roboto Slab', serif;
      font-weight: 700;
      font-size: 20px;
      color: var(--green);
      margin-bottom: 20px;
      position: relative; z-index: 1;
    }
    .step h3 { font-weight: 700; font-size: 16px; margin-bottom: 8px; color: var(--text); }
    .step p  { font-size: 14px; color: var(--text-dim); line-height: 1.75; }

    .pricing-card {
      background: var(--bg-card);
      border: 1px solid var(--border-green);
      border-radius: 22px;
      overflow: hidden;
      margin-top: 44px;
      box-shadow: 0 0 60px rgba(61,184,106,0.07);
    }
    .pricing-header {
      background: var(--green-soft);
      border-bottom: 1px solid var(--border-green);
      padding: 26px 32px;
    }
    .pricing-name    { font-family: 'Roboto Slab', serif; font-weight: 900; font-size: 20px; color: var(--text); margin-bottom: 6px; }
    .pricing-tagline { font-size: 15px; color: var(--text-dim); }
    .pricing-body    { padding: 30px 32px; }
    .pricing-row {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 18px 0;
      border-bottom: 1px solid var(--border);
      gap: 16px;
    }
    @media (max-width: 480px) {
      .pricing-row    { flex-direction: column; align-items: flex-start; gap: 8px; }
      .pricing-amount { font-size: 26px; }
      .pricing-body   { padding: 22px 20px; }
      .pricing-footer { padding: 0 20px 24px; }
      .pricing-header { padding: 22px 20px; }
    }
    .pricing-row:last-of-type { border-bottom: none; }
    .pricing-label        { font-size: 16px; color: var(--text); font-weight: 500; }
    .pricing-label small  { display: block; font-size: 13px; color: var(--text-muted); margin-top: 4px; font-weight: 400; }
    .pricing-amount       { font-family: 'Roboto Slab', serif; font-weight: 700; font-size: 28px; color: var(--yellow); white-space: nowrap; }
    .pricing-amount small { font-family: 'Noto Sans TC', sans-serif; font-size: 15px; font-weight: 400; color: var(--text-dim); }
    .pricing-footer       { padding: 0 32px 32px; }
    .pricing-note {
      font-size: 14px;
      color: var(--text-muted);
      line-height: 1.8;
      margin-bottom: 22px;
      padding: 14px 18px;
      background: rgba(255,255,255,0.03);
      border-radius: 10px;
    }
    .btn-pricing {
      display: flex;
      align-items: center;
      justify-content: center;
      background: var(--green);
      color: #fff;
      text-decoration: none;
      font-weight: 700;
      font-size: 17px;
      padding: 17px;
      border-radius: 11px;
      transition: background 0.2s, transform 0.15s;
      width: 100%;
    }
    .btn-pricing:hover { background: var(--green-hover); transform: translateY(-1px); }

    footer {
      text-align: center;
      padding: 36px 24px;
      border-top: 1px solid var(--border);
      font-size: 14px;
      color: var(--text-muted);
    }
    footer a { color: var(--text-muted); text-decoration: none; }
    footer a:hover { color: var(--text-dim); }

    @media (max-width: 480px) {
      .hero { padding: 60px 20px 70px; }
      .demo-section, .why-section, .whyus-section,
      .includes-section, .steps-section, .pricing-section {
        padding: 64px 20px;
      }
    }
  </style>
</head>
<body>

<!-- Hero -->
<section class="hero">
  <p class="hero-eyebrow">AI 數位名片</p>
  <h1>讓 AI <em>認識</em><br>你的品牌</h1>
  <p class="hero-sub">
    最有感的變化，就是讓你沒感覺。過去找餐廳會在網頁上打出關鍵字「台北中山區 義大利餐廳」，現在直接問 AI：「台北中山區附近哪家義大利麵適合帶小孩、好停車？」消費者已經不再搜尋關鍵字，而是在搜尋解決方案。你的品牌，AI 認識嗎？
  </p>
</section>

<hr class="section-divider">

<!-- Demo -->
<section class="demo-section" id="demo">
  <p class="section-label">示範頁面</p>
  <h2 class="section-title">名片頁面示範</h2>
  <p class="section-desc">每張名片依照品牌的風格客製設計。以下是一個日式家庭料理的示範版本。</p>
  <div class="demo-frame-wrap">
    <div class="demo-frame-label">
      <span>novum.to</span>/examples/sato-san
    </div>
    <div class="demo-frame">
      <div class="demo-frame-bar">
        <div class="dot dot-r"></div>
        <div class="dot dot-y"></div>
        <div class="dot dot-g"></div>
        <div class="demo-url">novum.to/examples/sato-san</div>
      </div>
      <iframe
        src="https://novum.to/examples/sato-san.html"
        class="demo-iframe"
        title="示範名片頁面"
        loading="lazy"
        scrolling="no"
      ></iframe>
    </div>
    <div class="demo-cta">
      <a href="https://novum.to/examples/sato-san.html" target="_blank" rel="noopener">開新視窗看完整頁面</a>
    </div>
  </div>
</section>

<hr class="section-divider">

<!-- Why Now -->
<section class="why-section">
  <p class="section-label">為什麼現在做</p>
  <h2 class="section-title">搜尋方式正在改變</h2>
  <p class="section-desc">不是未來的事，是現在已經在發生的事。</p>
  <div class="why-cards">
    <div class="why-card">
      <span class="why-card-icon">🔍</span>
      <h3>搜尋不再只是找連結</h3>
      <p>越來越多人直接問 ChatGPT、Google AI，AI 整理好幾個選項直接回答，省略許多時間，消費者依賴度上升。</p>
    </div>
    <div class="why-card">
      <span class="why-card-icon">👻</span>
      <h3>AI 看不懂的資訊，不會出現在答案裡</h3>
      <p>AI 回答問題靠的是它讀過、可信度高可驗證的資訊。如果你的資訊不在它的把握裡，你就不在它的參考範圍裡。</p>
    </div>
    <div class="why-card">
      <span class="why-card-icon">📅</span>
      <h3>消費者在 AI 裡完成選擇</h3>
      <p>消費者越來越在 AI 裡完成選擇，AI 如果沒見過你的產品、服務，就不屬於有機會曝光的那一邊。</p>
      <p style="font-size:12px;color:var(--text-muted);margin-top:10px;">來源：DataReportal x Similarweb, 2026</p>
    </div>
    <div class="why-card">
      <span class="why-card-icon">🌱</span>
      <h3>做一次，長期累積</h3>
      <p>不是每個月燒錢的廣告，是一次建置之後<strong>持續存在的數位資產</strong>，AI 爬蟲越爬越多次。</p>
    </div>
  </div>
</section>

<hr class="section-divider">

<!-- Why Us -->
<section class="whyus-section">
  <p class="section-label">為什麼找 NOVUM</p>
  <h2 class="section-title">我們做什麼</h2>
  <div class="whyus-list">
    <div class="whyus-item">
      <div class="whyus-num">01</div>
      <div class="whyus-content">
        <h3>名片背後有結構化資料，不是一般網頁</h3>
        <p>普通網頁是設計給人看的，AI 讀效率很差。我們在頁面底層埋入 Schema 結構化資料——這才是 AI 真正在讀的東西，讓它精確知道你是誰、在哪、賣什麼。你能提供那些情境下的需求。</p>
      </div>
    </div>
    <div class="whyus-item">
      <div class="whyus-num">02</div>
      <div class="whyus-content">
        <h3>進入 NOVUM AI Index</h3>
